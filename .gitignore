# ==============================================================================
# DSA Visualizer - .gitignore
# ==============================================================================

# =========================
# 1. General & OS Files
# =========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
ehthumbs_vista.db
[Tt]humbs.db
*.log
.env
.env.*
!.env.example
*.tmp
*.temp

# =========================
# 2. Frontend (React / TypeScript / Vite / Next.js)
# =========================
# Dependencies
node_modules/

# Build and Output
dist/
build/
.next/
.vite/
coverage/
*.tsbuildinfo
.npm

# =========================
# 3. Backend (Python)
# =========================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Tool Caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
coverage.xml

# Distribution
*.egg-info/
*.egg
build/
dist/

# =========================
# 4. IDEs and Editors
# =========================
.idea/
.vscode/*
# Allow shared project settings
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
*~

# =========================
# 5. Project-Specific Debug/Trace Outputs
# =========================
debug/
*_output.json
*_trace.json
output.json
output_utf8.json
heap_output.txt
leak_output.json
trace_output.json
tracer_output.json
test_results.txt

# =========================
# Merged from frontend/.gitignore
# =========================
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
out/
.vercel
*.pem
next-env.d.ts

# =========================
# 6. Temporary & Irrelevant Assets (Docs, Archives, Executables)
# =========================
# Office Documents
*.docx
*.doc
*.xlsx
*.xls
*.pptx
*.ppt
*.pdf

# Archives and Packages
*.zip
*.tar.gz
*.tar
*.gz
*.rar
*.7z
*.tgz

# OS / Executable Binaries
*.exe
*.dll
*.so
*.dylib
*.msi

# Browser profiling and playwright test profiles
/edge-profile-lan/
.playwright/

# =========================
# 7. Media & Screenshots (Root-level only to preserve subfolder assets)
# =========================
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.svg
/*.mp4
/screenshots/

# =========================
# 8. Temporary Test/Debug/Tracer Scripts
# =========================
take_screenshots.js
take_screenshots_*.js
take_screenshots/
debug_steps.py
debug_*.py
test_*.py
verify_*.py
print_*.py
fetch_*.py
scratch_*.py
query_*.py
check_*.py
find_*.py
test_debug_*.py
generate_mocks.py
frontend/public/mocks/

